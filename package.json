{
  "name": "jinx.to",
  "version": "1.0.0",
  "description": "Jinx.to is a platform for creating and managing your own AI agents.",
  "author": "beiryu",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "yarn": ">=1.22.0"
  },
  "scripts": {
    "prepare": "husky",
    "prebuild": "rimraf dist",
    "build": "nest build",
    "start": "node dist/main",
    "dev": "nest start --watch",
    "debug": "nest start --debug --watch",
    "update:package": "npx npm-check-updates -u",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "studio": "prisma studio",
    "seed": "nestjs-command",
    "seed:users": "nestjs-command seed:users",
    "seed:admin": "nestjs-command seed:admin",
    "seed:crypto-wallets": "nestjs-command seed:crypto-wallets",
    "seed:products": "nestjs-command seed:products",
    "seed:coupons": "nestjs-command seed:coupons",
    "seed:tickets": "nestjs-command seed:tickets",
    "seed:store-settings": "nestjs-command seed:store-settings",
    "seed:all": "nestjs-command seed:users && nestjs-command seed:admin && nestjs-command seed:crypto-wallets && nestjs-command seed:products && nestjs-command seed:coupons && nestjs-command seed:tickets && nestjs-command seed:store-settings",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "test": "jest --config test/jest.json --coverage --runInBand --passWithNoTests --forceExit",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config test/jest.json --runInBand"
  },
