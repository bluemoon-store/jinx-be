// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(uuid())
  userName    String    @unique
  email       String    @unique
  password    String
  firstName   String?   @map("first_name")
  lastName    String?   @map("last_name")
  isVerified  Boolean   @default(false) @map("is_verified")
  phone       String?
  role        Role      @default(USER)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  avatar      String?
  dateOfBirth DateTime? @map("date_of_birth")

  // Store related fields
  wallet          UserWallet?
  orders          Order[] @relation("UserOrders")
  cart            Cart?
  supportTickets  SupportTicket[] @relation("UserTickets")
  assignedTickets SupportTicket[] @relation("AssignedTickets")
  ticketMessages  TicketMessage[]
  reviews         OrderReview[]
  vouches         Vouch[]
  isBanned        Boolean         @default(false) @map("is_banned")
  bannedAt        DateTime?       @map("banned_at")
  bannedReason    String?         @map("banned_reason")
  isFlagged       Boolean         @default(false) @map("is_flagged")
  flaggedAt       DateTime?       @map("flagged_at")
  flaggedReason   String?         @map("flagged_reason")

  // Two-factor authentication
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")
  twoFactorSecret  String? @map("two_factor_secret")

  passwordResetOtp               String?   @map("password_reset_otp")
  passwordResetOtpExpiry         DateTime? @map("password_reset_otp_expiry")
  emailVerificationToken         String?   @map("email_verification_token")
  emailVerificationTokenExpiry   DateTime? @map("email_verification_token_expiry")
  invitedBy                      String?   @map("invited_by")
  invitedByUser                  User?     @relation("UserInvitations", fields: [invitedBy], references: [id])
  invitedUsers                   User[]    @relation("UserInvitations")
  invitationToken                String?   @map("invitation_token")
  invitationTokenExpiry          DateTime? @map("invitation_token_expiry")

  activityLogs     ActivityLog[]    @relation("ActorActivityLogs")
  dropClaims       DropClaim[]
  dropClaimVouches DropClaimVouch[]

  @@map("users")
}

enum Role {
  USER
  SUPER_ADMIN
  OWNER
  MOD
  ALLIANCE
  SUPPORT
}

enum CouponDiscountType {
  PERCENT
  FIXED
}

enum CouponCategoryScope {
  ALL
  SPECIFIC
}

model ProductCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  icon        String? // S3 key for category icon
  isActive    Boolean   @default(true) @map("is_active")
  sortOrder   Int       @default(0) @map("sort_order")
  products    Product[]
  coupons     CouponCategory[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("product_categories")
}

model Coupon {
  id            String              @id @default(uuid())
  code          String              @unique
  description   String?             @map("description")
  discountType  CouponDiscountType  @map("discount_type")
  discountValue Decimal             @db.Decimal(20, 8) @map("discount_value")
  expiresAt     DateTime?           @map("expires_at") // null => never expires
  maxUses       Int?                @map("max_uses") // null => unlimited
  usedCount     Int                 @default(0) @map("used_count")
  categoryScope CouponCategoryScope @default(ALL) @map("category_scope")
  isActive      Boolean             @default(true) @map("is_active")
  categories    CouponCategory[]
  orders        Order[]
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  deletedAt     DateTime?           @map("deleted_at")

  @@index([expiresAt])
  @@index([deletedAt])
  @@map("coupons")
}

model CouponCategory {
  couponId   String          @map("coupon_id")
  categoryId String          @map("category_id")
  coupon     Coupon          @relation(fields: [couponId], references: [id], onDelete: Cascade)
  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([couponId, categoryId])
  @@index([categoryId])
  @@map("coupon_categories")
}

// Product
model Product {
  id              String          @id @default(uuid())
  name            String
  slug            String          @unique
  description     String          @db.Text
  price           Decimal         @db.Decimal(20, 8) // Support crypto decimals (fallback when no variants)
  stockQuantity   Int             @default(0) @map("stock_quantity")
  isActive        Boolean         @default(true) @map("is_active")
  sortOrder       Int             @default(0) @map("sort_order")
  categoryId      String          @map("category_id")
  category        ProductCategory @relation(fields: [categoryId], references: [id])
  images          ProductImage[]
  deliveryType    DeliveryType    @default(INSTANT) @map("delivery_type")
  deliveryContent String?         @map("delivery_content") @db.Text // For instant delivery
  cartItems       CartItem[]
  orderItems      OrderItem[]

  shortNotice     String?   @map("short_notice")
  flair           String?   @map("flair")
  iconUrl         String?   @map("icon_url")
  isHot           Boolean   @default(false) @map("is_hot")
  isNew           Boolean   @default(false) @map("is_new")
  isNFA           Boolean   @default(false) @map("is_nfa")
  isRestocked     Boolean   @default(false) @map("is_restocked")
  launchedAt      DateTime? @map("launched_at")
  restockedAt     DateTime? @map("restocked_at")
  countryOfOrigin String?   @map("country_of_origin")
  redeemProcess   String?   @map("redeem_process") @db.Text
  warrantyText    String?   @map("warranty_text") @db.Text
  warrantyMinutes     Int       @default(15) @map("warranty_minutes")

  variants    ProductVariant[]
  drops       Drop[]
  relatedFrom ProductRelated[] @relation("RelatedFrom")
  relatedTo   ProductRelated[] @relation("RelatedTo")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([categoryId])
  @@index([slug])
  @@index([isActive])
  @@map("products")
}

model ProductVariant {
  id            String   @id @default(uuid())
  productId     String   @map("product_id")
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  label         String
  price         Decimal  @db.Decimal(20, 8)
  stockQuantity Int      @default(0) @map("stock_quantity")
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  cartItems     CartItem[]
  orderItems    OrderItem[]
  stockLines    ProductStockLine[]
  drops         Drop[]
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  @@index([productId])
  @@map("product_variants")
}

enum StockLineStatus {
  AVAILABLE
  RESERVED
  SOLD
  REFUNDED
}

model ProductStockLine {
  id             String          @id @default(uuid())
  variantId      String          @map("variant_id")
  variant        ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict)
  content        String          @db.Text
  contentHash    String          @map("content_hash")
  status         StockLineStatus @default(AVAILABLE)

  orderItemId    String?         @map("order_item_id")
  orderItem      OrderItem?      @relation(fields: [orderItemId], references: [id], onDelete: SetNull)
  reservedAt     DateTime?       @map("reserved_at")
  reservedUntil  DateTime?       @map("reserved_until")
  soldAt         DateTime?       @map("sold_at")
  retiredAt      DateTime?       @map("retired_at")

  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  claims         DropClaim[]

  @@unique([variantId, contentHash])
  @@index([variantId, status])
  @@index([orderItemId])
  @@index([status, reservedUntil])
  @@map("product_stock_lines")
}

model Drop {
  id            String         @id @default(uuid())
  productId     String         @map("product_id")
  variantId     String         @map("variant_id")
  product       Product        @relation(fields: [productId], references: [id])
  variant       ProductVariant @relation(fields: [variantId], references: [id])
  description   String?
  quantity      Int
  claimedCount  Int            @default(0) @map("claimed_count")
  allowedEmails String[]       @default([]) @map("allowed_emails")
  expiresAt     DateTime?      @map("expires_at")
  isActive      Boolean        @default(true) @map("is_active")
  claims        DropClaim[]
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  @@index([productId])
  @@index([variantId])
  @@index([isActive, expiresAt])
  @@index([deletedAt])
  @@map("drops")
}

model DropClaim {
  id             String            @id @default(uuid())
  dropId         String            @map("drop_id")
  userId         String            @map("user_id")
  stockLineId    String?           @unique @map("stock_line_id")
  claimedContent String            @db.Text @map("claimed_content")
  drop           Drop              @relation(fields: [dropId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  stockLine      ProductStockLine? @relation(fields: [stockLineId], references: [id], onDelete: SetNull)
  claimedAt      DateTime          @default(now()) @map("claimed_at")
  vouches        DropClaimVouch[]

  @@unique([dropId, userId])
  @@index([userId])
  @@map("drop_claims")
}

model DropClaimVouch {
  id          String    @id @default(uuid())
  dropClaimId String    @map("drop_claim_id")
  dropClaim   DropClaim @relation(fields: [dropClaimId], references: [id], onDelete: Cascade)
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageKey    String    @map("image_key")
  imageUrl    String?   @map("image_url")
  caption     String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@index([dropClaimId])
  @@index([userId])
  @@index([createdAt])
  @@map("drop_claim_vouches")
}

model ProductRelated {
  productId        String  @map("product_id")
  relatedProductId String  @map("related_product_id")
  product          Product @relation("RelatedFrom", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct   Product @relation("RelatedTo", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@id([productId, relatedProductId])
  @@map("product_related")
}

enum DeliveryType {
  INSTANT // Digital delivery (sent immediately)
  MANUAL // Requires admin action
  DOWNLOAD // File download link
}

// Product Images
model ProductImage {
  id        String    @id @default(uuid())
  productId String    @map("product_id")
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  key       String // S3 key
  url       String? // Optional cached URL
  isPrimary Boolean   @default(false) @map("is_primary")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([productId])
  @@map("product_images")
}

// Shopping Cart
model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("carts")
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String   @map("cart_id")
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)

  variantId     String?         @map("variant_id")
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  unitPrice     Decimal?        @db.Decimal(20, 8) @map("unit_price")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([cartId])
  @@index([variantId])
  @@map("cart_items")
}

// Orders & Payments
model Order {
  id             String          @id @default(uuid())
  orderNumber    String          @unique @map("order_number") // e.g., ORD-20260129-XXXXX
  userId         String          @map("user_id")
  user           User            @relation("UserOrders", fields: [userId], references: [id])
  buyerProtection Boolean        @default(false) @map("buyer_protection")
  buyerProtectionAmount Decimal  @default(0) @map("buyer_protection_amount") @db.Decimal(20, 8)
  status         OrderStatus     @default(PENDING)
  subtotalAmount Decimal         @default(0) @map("subtotal_amount") @db.Decimal(20, 8)
  discountAmount Decimal         @default(0) @map("discount_amount") @db.Decimal(20, 8)
  couponId       String?         @map("coupon_id")
  couponCode     String?         @map("coupon_code")
  coupon         Coupon?         @relation(fields: [couponId], references: [id], onDelete: SetNull)
  totalAmount    Decimal         @map("total_amount") @db.Decimal(20, 8)
  currency       String // USD, BTC, ETH, etc.
  cryptoPayment  CryptoPayment?
  fiatPayment    FiatPayment?
  items          OrderItem[]
  review         OrderReview?
  supportTickets SupportTicket[]
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  completedAt    DateTime?       @map("completed_at")
  cancelledAt    DateTime?       @map("cancelled_at")
  deletedAt      DateTime?       @map("deleted_at")

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
  @@index([couponId])
  @@map("orders")
}

enum OrderStatus {
  PENDING // Awaiting payment
  COMPLETED // Order delivered (payment confirmed)
  CANCELLED // Order cancelled
  REFUNDED // Payment refunded
}

model OrderReview {
  id        String   @id @default(uuid())
  orderId   String   @unique @map("order_id")
  userId    String   @map("user_id")
  rating    Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  deletedAt DateTime?    @map("deleted_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("order_reviews")
}

enum VouchStatus {
  PENDING
  APPROVED
}

model Vouch {
  id          String      @id @default(uuid())
  orderItemId String      @map("order_item_id")
  orderItem   OrderItem   @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageKey    String      @map("image_key")
  imageUrl    String?     @map("image_url")
  caption     String?     @db.Text
  status      VouchStatus @default(PENDING)
  approvedAt  DateTime?   @map("approved_at")
  approvedBy  String?     @map("approved_by")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  @@index([orderItemId])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@map("vouches")
}

model OrderItem {
  id               String    @id @default(uuid())
  orderId          String    @map("order_id")
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId        String    @map("product_id")
  product          Product   @relation(fields: [productId], references: [id])
  quantity         Int
  priceAtPurchase  Decimal   @map("price_at_purchase") @db.Decimal(20, 8)
  deliveredContent String?   @map("delivered_content") @db.Text // Actual content delivered
  deliveredAt      DateTime? @map("delivered_at")
  firstViewedAt    DateTime? @map("first_viewed_at")

  variantId     String?         @map("variant_id")
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  variantLabel  String?         @map("variant_label")
  stockLines    ProductStockLine[]
  vouches       Vouch[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([variantId])
  @@map("order_items")
}

// Crypto Payment System
model CryptoPayment {
  id      String @id @default(uuid())
  orderId String @unique @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Cryptocurrency info
  cryptocurrency CryptoCurrency
  network        String? // e.g., "mainnet", "ERC20", "BEP20", "TRC20"

  // Payment address (generated from system HD wallet)
  paymentAddress      String @map("payment_address")
  derivationIndex     Int    @map("derivation_index")
  derivationPath      String @map("derivation_path")
  encryptedPrivateKey String @map("encrypted_private_key") @db.Text

  // Amount info
  amount       Decimal  @db.Decimal(30, 18) // Crypto amount (support 18 decimals for ETH)
  amountUsd    Decimal  @map("amount_usd") @db.Decimal(20, 2) // USD value at creation
  exchangeRate Decimal? @map("exchange_rate") @db.Decimal(20, 8) // Rate at payment time

  // Platform wallet info
  platformWalletAddress String @map("platform_wallet_address")

  // Payment status
  status PaymentStatus @default(PENDING)

  // Transaction info
  txHash                String? @map("tx_hash") // Incoming transaction hash
  forwardTxHash         String? @map("forward_tx_hash") // Outgoing transaction hash
  confirmations         Int     @default(0)
  requiredConfirmations Int     @default(3) @map("required_confirmations")

  // Timestamps
  expiresAt   DateTime  @map("expires_at")
  paidAt      DateTime? @map("paid_at")
  confirmedAt DateTime? @map("confirmed_at")
  forwardedAt DateTime? @map("forwarded_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Metadata
  metadata Json? // Additional info (network fee, gas price, etc.)

  @@index([paymentAddress])
  @@index([status])
  @@index([txHash])
  @@index([cryptocurrency])
  @@index([expiresAt])
  @@map("crypto_payments")
}

enum CryptoCurrency {
  BTC // Bitcoin
  ETH // Ethereum
  LTC // Litecoin
  BCH // Bitcoin Cash
  USDT_ERC20 // USDT on Ethereum
  USDT_TRC20 // USDT on Tron
  USDC_ERC20 // USDC on Ethereum
  SOL // Solana (native)
}

enum PaymentStatus {
  PENDING // Waiting for payment
  PAID // Payment detected (but not confirmed)
  CONFIRMING // Waiting for confirmations
  CONFIRMED // Payment confirmed (order can proceed)
  FORWARDING // Forwarding to platform wallet
  FORWARDED // Successfully forwarded
  FORWARDING_FAILED // Forwarding to platform wallet failed
  EXPIRED // Payment window expired (15 min)
  FAILED // Payment processing failed
}

// Fiat Payment System (hosted gateways, e.g. CHIME / Polapine)
model FiatPayment {
  id      String @id @default(uuid())
  orderId String @unique @map("order_id")
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Which provider handled this payment
  gateway PaymentGateway

  // Amount info (fiat is charged in the order currency, typically USD)
  amount   Decimal @db.Decimal(20, 2)
  currency String // USD, EUR, etc.

  // Provider references
  externalId        String? @map("external_id") // Gateway invoice / payment-link id
  externalReference String? @map("external_reference") // order_reference we send to the gateway
  checkoutUrl       String? @map("checkout_url") @db.Text // Hosted payment page URL

  // Payment status
  status FiatPaymentStatus @default(PENDING)

  // Timestamps
  expiresAt DateTime  @map("expires_at")
  paidAt    DateTime? @map("paid_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  // Metadata (raw gateway payloads, etc.)
  metadata Json?

  @@index([status])
  @@index([externalId])
  @@index([expiresAt])
  @@index([gateway])
  @@map("fiat_payments")
}

enum PaymentGateway {
  CHIME
}

enum FiatPaymentStatus {
  PENDING // Awaiting payment (checkout created)
  PROCESSING // Gateway reports payment in progress
  PAID // Payment confirmed by gateway (order can proceed)
  FAILED // Payment failed / declined
  EXPIRED // Checkout window expired
  CANCELLED // Buyer cancelled
  REFUNDED // Payment refunded
}

// System Wallet Index Tracker
model SystemWalletIndex {
  id             String         @id @default(uuid())
  cryptocurrency CryptoCurrency @unique
  nextIndex      Int            @default(0) @map("next_index")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("system_wallet_indexes")
}

// Crypto Exchange Rate Cache
model CryptoExchangeRate {
  id             String         @id @default(uuid())
  cryptocurrency CryptoCurrency
  fiatCurrency   String         @default("USD") @map("fiat_currency")
  rate           Decimal        @db.Decimal(20, 8)
  provider       String // "tatum", "kraken", etc.
  expiresAt      DateTime       @map("expires_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@unique([cryptocurrency, fiatCurrency])
  @@index([cryptocurrency])
  @@index([expiresAt])
  @@map("crypto_exchange_rates")
}

// User Wallet/Balance System
model UserWallet {
  id           String              @id @default(uuid())
  userId       String              @unique @map("user_id")
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance      Decimal             @default(0) @db.Decimal(20, 2) // USD balance
  transactions WalletTransaction[]
  topUps       WalletTopUp[]
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  @@map("user_wallets")
}

model WalletTopUp {
  id                    String         @id @default(uuid())
  walletId              String         @map("wallet_id")
  wallet                UserWallet     @relation(fields: [walletId], references: [id], onDelete: Cascade)
  cryptocurrency        CryptoCurrency
  network               String?
  paymentAddress        String         @map("payment_address")
  derivationIndex       Int            @map("derivation_index")
  derivationPath        String         @map("derivation_path")
  encryptedPrivateKey   String         @map("encrypted_private_key")
  amount                Decimal        @db.Decimal(30, 18)
  amountUsd             Decimal        @map("amount_usd") @db.Decimal(20, 2)
  exchangeRate          Decimal?       @map("exchange_rate") @db.Decimal(20, 8)
  platformWalletAddress String         @map("platform_wallet_address")
  status                PaymentStatus  @default(PENDING)
  txHash                String?        @map("tx_hash")
  forwardTxHash         String?        @map("forward_tx_hash")
  confirmations         Int            @default(0)
  requiredConfirmations Int            @default(3) @map("required_confirmations")
  expiresAt             DateTime       @map("expires_at")
  paidAt                DateTime?      @map("paid_at")
  confirmedAt           DateTime?      @map("confirmed_at")
  forwardedAt           DateTime?      @map("forwarded_at")
  metadata              Json?
  creditedAt            DateTime?      @map("credited_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  @@index([walletId])
  @@index([status])
  @@index([paymentAddress])
  @@map("wallet_topups")
}

model WalletTransaction {
  id          String                @id @default(uuid())
  walletId    String                @map("wallet_id")
  wallet      UserWallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type        WalletTransactionType
  amount      Decimal               @db.Decimal(20, 2)
  balance     Decimal               @db.Decimal(20, 2) // Balance after transaction
  description String
  referenceId String?               @map("reference_id") // Order ID, etc.
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  @@index([walletId])
  @@index([type])
  @@map("wallet_transactions")
}

enum WalletTransactionType {
  DEPOSIT // Add funds
  PURCHASE // Product purchase
  REFUND // Order refund
  ADMIN_ADJUST // Admin adjustment
}

// Support Ticket System
model SupportTicket {
  id               String          @id @default(uuid())
  ticketNumber     String          @unique @map("ticket_number") // e.g., TKT-20260129-XXXXX
  orderId          String?         @map("order_id")
  order            Order?          @relation(fields: [orderId], references: [id])
  userId           String          @map("user_id")
  user             User            @relation("UserTickets", fields: [userId], references: [id])
  subject          String
  status           TicketStatus    @default(OPEN)
  priority         TicketPriority  @default(MEDIUM)
  messages         TicketMessage[]
  assignedToId     String?         @map("assigned_to_id")
  assignedTo       User?           @relation("AssignedTickets", fields: [assignedToId], references: [id])
  lastStaffReadAt  DateTime?       @map("last_staff_read_at")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")
  closedAt         DateTime?       @map("closed_at")
  deletedAt        DateTime?       @map("deleted_at")

  @@index([userId])
  @@index([orderId])
  @@index([status])
  @@index([assignedToId])
  @@map("support_tickets")
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_USER
  RESOLVED
  CLOSED
  CANCELLED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model TicketMessage {
  id          String              @id @default(uuid())
  ticketId    String              @map("ticket_id")
  ticket      SupportTicket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId      String              @map("user_id")
  user        User                @relation(fields: [userId], references: [id])
  message     String              @db.Text
  isStaff     Boolean             @default(false) @map("is_staff")
  attachments TicketAttachment[]
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@index([ticketId])
  @@map("ticket_messages")
}

model TicketAttachment {
  id        String        @id @default(uuid())
  messageId String        @map("message_id")
  message   TicketMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  url       String
  fileName  String        @map("file_name")
  mimeType  String        @map("mime_type")
  size      Int
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([messageId])
  @@map("ticket_attachments")
}

// CMS Content System
model CmsContent {
  id          String      @id @default(uuid())
  key         String      @unique // faq, terms, privacy, etc.
  type        ContentType
  title       String
  content     String      @db.Text
  isPublished Boolean     @default(true) @map("is_published")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  @@map("cms_contents")
}

enum ContentType {
  FAQ
  TERMS
  PRIVACY
  REFUND
  COOKIE
  LANDING_PAGE
  ABOUT
}

// System Settings
model SystemSettings {
  id        String   @id @default(uuid())
  key       String   @unique // telegram_channel, telegram_bot_token, etc.
  value     String   @db.Text
  category  String // social, payment, general, etc.
  isPublic  Boolean  @default(false) @map("is_public") // Can be exposed to frontend
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@map("system_settings")
}

model FaqCategory {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  position  Int       @default(0)
  items     FaqItem[]
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([position])
  @@index([deletedAt])
  @@map("faq_categories")
}

model FaqItem {
  id         String      @id @default(uuid())
  categoryId String      @map("category_id")
  category   FaqCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  question   String
  answerHtml String      @map("answer_html") @db.Text
  position   Int         @default(0)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  deletedAt  DateTime?   @map("deleted_at")

  @@index([categoryId, position])
  @@index([deletedAt])
  @@map("faq_items")
}

// Analytics/Statistics
model Analytics {
  id        String       @id @default(uuid())
  type      AnalyticType
  date      DateTime     @db.Date
  key       String // product_id, user_id, category_id, etc.
  value     Float
  metadata  Json? // Additional data
  createdAt DateTime     @default(now()) @map("created_at")

  @@unique([type, date, key])
  @@index([type, date])
  @@map("analytics")
}

enum AnalyticType {
  DAILY_SALES
  PRODUCT_VIEWS
  CATEGORY_VIEWS
  REVENUE
  USER_SIGNUPS
  ORDERS_COUNT
}

model ActivityLog {
  id       String @id @default(uuid())

  actorId    String? @map("actor_id")
  actorEmail String? @map("actor_email")
  actorName  String? @map("actor_name")
  actorRole  Role?   @map("actor_role")

  action    String
  category  ActivityLogCategory
  severity  ActivityLogSeverity @default(INFO)

  resourceType  String? @map("resource_type")
  resourceId    String? @map("resource_id")
  resourceLabel String? @map("resource_label")

  before   Json?
  after    Json?
  metadata Json?

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent") @db.VarChar(512)
  requestId String? @map("request_id")

  status       ActivityLogStatus @default(SUCCESS)
  errorMessage String?           @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")

  actor User? @relation("ActorActivityLogs", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId, createdAt(sort: Desc)])
  @@index([category, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@map("activity_logs")
}

enum ActivityLogCategory {
  PRODUCT
  PRODUCT_CATEGORY
  ORDER
  USER
  COUPON
  DROP
  WALLET
  CRYPTO_PAYMENT
  REVIEW
  VOUCH
  CONTENT
  SETTINGS
}

enum ActivityLogSeverity {
  INFO
  WARNING
  CRITICAL
}

enum ActivityLogStatus {
  SUCCESS
  FAILURE
}
