<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="x-apple-disable-message-reformatting">
<title>Order Confirmed</title>
<link href="https://fonts.googleapis.com/css2?family=Commissioner:wght@400;500;600;700&display=swap" rel="stylesheet" type="text/css">
<style type="text/css">
@import url('https://fonts.googleapis.com/css2?family=Commissioner:wght@400;500;600;700&display=swap');
body,table,td,p,a{-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;}
table,td{mso-table-lspace:0pt;mso-table-rspace:0pt;}
img{-ms-interpolation-mode:bicubic;border:0;outline:none;text-decoration:none;display:block;}
body{margin:0;padding:0;background-color:#051329;}
@media only screen and (max-width:600px){
  .email-wrap{width:100%!important;}
  .card-pad{padding:16px!important;}
  .illus-img{width:100%!important;height:auto!important;}
  .btn-full{width:100%!important;}
  .detail-row td{font-size:14px!important;}
  .footer-links td{font-size:12px!important;padding-right:8px!important;}
  .social-gap{padding-right:10px!important;}
}
</style>
</head>
<body style="margin:0;padding:0;background-color:#051329;font-family:'Commissioner',Arial,sans-serif;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#040e20;background-image:linear-gradient(90deg,rgba(0,0,0,0.2) 0%,rgba(0,0,0,0.2) 100%),linear-gradient(90deg,#051329 0%,#051329 100%);">
<tr>
<td align="center" style="padding:60px 20px 40px;">

<table role="presentation" class="email-wrap" width="580" cellpadding="0" cellspacing="0" border="0" style="max-width:580px;width:100%;">

  <!-- MAIN CARD -->
  <tr>
    <td class="card-pad" style="background-color:#071935;border:1px solid rgba(238,238,238,0.05);border-radius:8px;padding:24px;overflow:hidden;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">

      <!-- HEADER -->
      <tr>
        <td>
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
          <tr>
            <td style="padding-left:12px;vertical-align:middle;">
              <img src="{{asset_url}}/jinx-header-logo.svg" alt="Jinx" width="87" height="48" style="display:block;border:0;outline:none;text-decoration:none;">
            </td>
            <td align="right" style="vertical-align:middle;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="background-color:#071935;border:1px solid rgba(238,238,238,0.1);border-radius:8px;padding:0;">
                  <a href="{{store_link}}" style="display:block;padding:4px 16px;text-decoration:none;">
                  <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                      <td style="padding-right:8px;vertical-align:middle;line-height:0;">
                        <img src="{{asset_url}}/globe.svg" alt="" width="16" height="16" style="display:block;border:0;outline:none;text-decoration:none;">
                      </td>
                      <td style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:#ffffff;line-height:28px;letter-spacing:-0.16px;white-space:nowrap;vertical-align:middle;">Visit Store</td>
                    </tr>
                  </table>
                  </a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
        </table>
        </td>
      </tr>

      <!-- DIVIDER 1 -->
      <tr>
        <td style="padding-top:24px;font-size:0;line-height:0;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr><td height="1" bgcolor="#1e2e48" style="font-size:0;line-height:0;mso-line-height-rule:exactly;">&nbsp;</td></tr></table>
        </td>
      </tr>

      <!-- ILLUSTRATION -->
      <tr>
        <td align="center" style="padding-top:24px;">
          <img class="illus-img" src="{{asset_url}}/order-confirmed.png" alt="Order Confirmed" width="320" height="320" style="display:block;border:0;outline:none;text-decoration:none;max-width:100%;height:auto;">
        </td>
      </tr>

      <!-- TITLE + SUBTITLE -->
      <tr>
        <td align="center" style="padding-top:24px;">
          <p style="margin:0 0 5px;font-family:'Commissioner',Arial,sans-serif;font-size:24px;font-weight:700;color:#ffffff;line-height:32px;letter-spacing:0.48px;text-align:center;">Order Confirmed</p>
          <p style="margin:0;font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:rgba(255,255,255,0.75);line-height:24px;text-align:center;">Thank you for your purchase from Jinx.to Store.<br>Your order has been received successfully,<br>and your payment has been confirmed.</p>
        </td>
      </tr>

      <!-- DIVIDER 2 -->
      <tr>
        <td style="padding-top:24px;font-size:0;line-height:0;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr><td height="1" bgcolor="#1e2e48" style="font-size:0;line-height:0;mso-line-height-rule:exactly;">&nbsp;</td></tr></table>
        </td>
      </tr>

      <!-- ORDER DETAILS BOX -->
      <tr>
        <td style="padding-top:24px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
              <td style="background-color:#0d1b35;border:1px solid rgba(238,238,238,0.1);border-radius:12px;padding:20px;">
                <table role="presentation" width="100%" class="detail-row" cellpadding="0" cellspacing="0" border="0">

                  <!-- Order ID -->
                  <tr>
                    <td style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:rgba(255,255,255,0.75);line-height:28px;letter-spacing:-0.16px;padding-bottom:20px;">Order ID</td>
                    <td align="right" style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:#ffffff;line-height:28px;letter-spacing:-0.16px;white-space:nowrap;padding-bottom:20px;">{{order_id}}</td>
                  </tr>

                  <!-- Divider -->
                  <tr>
                    <td colspan="2" style="padding-bottom:20px;font-size:0;line-height:0;">
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr><td height="1" bgcolor="#253249" style="font-size:0;line-height:0;mso-line-height-rule:exactly;">&nbsp;</td></tr></table>
                    </td>
                  </tr>

                  <!-- Items -->
                  {{#if line_items.length}}
                  <tr>
                    <td colspan="2" style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:rgba(255,255,255,0.75);line-height:28px;letter-spacing:-0.16px;padding-bottom:12px;">Items</td>
                  </tr>
                  {{#each line_items}}
                  <tr>
                    <td style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:#ffffff;line-height:22px;letter-spacing:-0.16px;padding-bottom:12px;">{{this.name}}{{#if this.variant}} · {{this.variant}}{{/if}}<br><span style="font-size:13px;font-weight:500;color:rgba(255,255,255,0.6);">{{this.quantity}} × {{this.unit_price}}</span></td>
                    <td align="right" style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:#ffffff;line-height:22px;letter-spacing:-0.16px;white-space:nowrap;vertical-align:top;padding-bottom:12px;">{{this.line_total}}</td>
                  </tr>
                  {{/each}}

                  <!-- Divider -->
                  <tr>
                    <td colspan="2" style="padding-bottom:20px;font-size:0;line-height:0;">
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr><td height="1" bgcolor="#253249" style="font-size:0;line-height:0;mso-line-height-rule:exactly;">&nbsp;</td></tr></table>
                    </td>
                  </tr>
                  {{/if}}

                  <!-- Payment Method -->
                  <tr>
                    <td style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:rgba(255,255,255,0.75);line-height:28px;letter-spacing:-0.16px;padding-bottom:12px;">Payment Method</td>
                    <td align="right" style="padding-bottom:12px;">
                      <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="right">
                        <tr>
                          <td style="padding-right:10px;vertical-align:middle;line-height:0;">
                            <img src="{{asset_url}}/bitcoin.svg" alt="Bitcoin" width="20" height="20" style="display:block;border:0;outline:none;text-decoration:none;">
                          </td>
                          <td style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:#ffffff;line-height:28px;letter-spacing:-0.16px;white-space:nowrap;vertical-align:middle;">{{payment_method}}</td>
                        </tr>
                      </table>
                    </td>
                  </tr>

                  <!-- Subtotal -->
                  {{#if subtotal}}
                  <tr>
                    <td style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:rgba(255,255,255,0.75);line-height:28px;letter-spacing:-0.16px;padding-bottom:12px;">Subtotal</td>
                    <td align="right" style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:#ffffff;line-height:28px;letter-spacing:-0.16px;white-space:nowrap;padding-bottom:12px;">{{subtotal}}</td>
                  </tr>
                  {{/if}}

                  <!-- Discount -->
                  {{#if discount}}
                  <tr>
                    <td style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:rgba(255,255,255,0.75);line-height:28px;letter-spacing:-0.16px;padding-bottom:12px;">Discount</td>
                    <td align="right" style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:#ffffff;line-height:28px;letter-spacing:-0.16px;white-space:nowrap;padding-bottom:12px;">&minus;{{discount}}</td>
                  </tr>
                  {{/if}}

                  <!-- Amount Paid -->
                  <tr>
                    <td style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:rgba(255,255,255,0.75);line-height:28px;letter-spacing:-0.16px;padding-bottom:12px;">Amount Paid</td>
                    <td align="right" style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:#ffffff;line-height:28px;letter-spacing:-0.16px;white-space:nowrap;padding-bottom:12px;">{{amount}}</td>
                  </tr>

                  <!-- Order Date -->
                  <tr>
                    <td style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:rgba(255,255,255,0.75);line-height:28px;letter-spacing:-0.16px;">Order Date</td>
                    <td align="right" style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:#ffffff;line-height:28px;letter-spacing:-0.16px;white-space:nowrap;">{{date}}</td>
                  </tr>

                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- VIEW ORDER BUTTON -->
      <tr>
        <td align="center" style="padding-top:24px;">
          <table role="presentation" class="btn-full" cellpadding="0" cellspacing="0" border="0" style="width:100%;">
            <tr>
              <td align="center" style="background-color:#eb2dff;border-radius:8px;mso-padding-alt:12px 16px;">
                <a href="{{dashboard_link}}" style="display:block;padding:12px 16px;text-decoration:none;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center">
                  <tr>
                    <td style="padding-right:8px;vertical-align:middle;line-height:0;">
                      <img src="{{asset_url}}/view-order-icon.svg" alt="" width="18" height="18" style="display:block;border:0;outline:none;text-decoration:none;">
                    </td>
                    <td style="font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:#ffffff;line-height:28px;letter-spacing:-0.16px;white-space:nowrap;vertical-align:middle;">View Order</td>
                  </tr>
                </table>
                </a>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- MANUAL LINK -->
      <tr>
        <td align="center" style="padding-top:24px;">
          <p style="margin:0;font-family:'Commissioner',Arial,sans-serif;font-size:16px;font-weight:500;color:rgba(255,255,255,0.75);line-height:24px;text-align:center;">if you are a member, view manually using this link:<br><a href="{{dashboard_link}}" style="color:#eb2dff;text-decoration:none;">{{dashboard_link}}</a></p>
        </td>
      </tr>

      <!-- DIVIDER 3 -->
      <tr>
        <td style="padding-top:24px;font-size:0;line-height:0;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"><tr><td height="1" bgcolor="#1e2e48" style="font-size:0;line-height:0;mso-line-height-rule:exactly;">&nbsp;</td></tr></table>
        </td>
      </tr>

      <!-- SECURITY BADGE -->
      <tr>
        <td style="padding-top:24px;">
          <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
            <tr>
              <td align="center" style="background-color:#051329;border:1px solid rgba(238,238,238,0.05);border-radius:8px;padding:12px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="padding-right:10px;vertical-align:middle;line-height:0;">
                    <img src="{{asset_url}}/secure-email-jinx-system-icon.svg" alt="" width="18" height="18" style="display:block;border:0;outline:none;text-decoration:none;">
                  </td>
                  <td style="font-family:'Commissioner',Arial,sans-serif;font-size:14px;font-weight:500;color:#faf8ff;line-height:24px;letter-spacing:-0.14px;white-space:nowrap;vertical-align:middle;">Secure email from Jinx System</td>
                </tr>
              </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>

    </table>
    </td>
  </tr>
  <!-- END MAIN CARD -->

  <!-- FOOTER -->
  <tr>
    <td align="center" style="padding:32px 40px;">
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center" style="padding-bottom:10px;">
          <img src="{{asset_url}}/jinx-footer-logo.svg" alt="Jinx" width="69" height="38" style="display:block;border:0;outline:none;text-decoration:none;margin:0 auto;">
        </td>
      </tr>
      <tr>
        <td align="center" style="padding-bottom:20px;">
          <p style="margin:0;font-family:'Commissioner',Arial,sans-serif;font-size:14px;font-weight:500;color:rgba(158,160,198,0.75);line-height:20px;text-align:center;white-space:nowrap;">Your one stop store for all digital purchases</p>
        </td>
      </tr>
      <tr>
        <td align="center" style="padding-bottom:20px;">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0">
          <tr>
            <td class="social-gap" style="padding-right:15px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr><td style="background-color:#071935;border:1px solid rgba(238,238,238,0.1);border-radius:8px;padding:0;line-height:0;font-size:0;"><a href="{{telegram_link}}" style="display:block;padding:10px;line-height:0;font-size:0;"><img src="{{asset_url}}/telegram.svg" alt="Telegram" width="18" height="18" style="display:block;border:0;outline:none;text-decoration:none;"></a></td></tr></table>
            </td>
            <td class="social-gap" style="padding-right:15px;">
              <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr><td style="background-color:#071935;border:1px solid rgba(238,238,238,0.1);border-radius:8px;padding:0;line-height:0;font-size:0;"><a href="{{discord_link}}" style="display:block;padding:10px;line-height:0;font-size:0;"><img src="{{asset_url}}/discord.svg" alt="Discord" width="18" height="18" style="display:block;border:0;outline:none;text-decoration:none;"></a></td></tr></table>
            </td>
            <td>
              <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr><td style="background-color:#071935;border:1px solid rgba(238,238,238,0.1);border-radius:8px;padding:0;line-height:0;font-size:0;"><a href="{{store_link}}" style="display:block;padding:10px;line-height:0;font-size:0;"><img src="{{asset_url}}/globe.svg" alt="Website" width="18" height="18" style="display:block;border:0;outline:none;text-decoration:none;"></a></td></tr></table>
            </td>
          </tr>
        </table>
        </td>
      </tr>
      <tr>
        <td align="center" style="padding-bottom:20px;">
          <p style="margin:0;font-family:'Commissioner',Arial,sans-serif;font-size:14px;font-weight:500;color:rgba(158,160,198,0.72);line-height:20px;text-align:center;">Questions or concerns? Get in touch with our <a href="{{support_link}}" style="color:#eb2dff;text-decoration:none;">support.</a></p>
        </td>
      </tr>
      <tr>
        <td align="center">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0">
          <tr>
            <td style="font-family:'Commissioner',Arial,sans-serif;font-size:14px;font-weight:500;color:rgba(158,160,198,0.72);line-height:20px;white-space:nowrap;padding-right:15px;"><a href="{{terms_link}}" style="color:rgba(158,160,198,0.72);text-decoration:none;">Terms</a></td>
            <td style="font-family:Arial,sans-serif;font-size:12px;color:rgba(158,160,198,0.36);line-height:18px;white-space:nowrap;padding-right:15px;">|</td>
            <td style="font-family:'Commissioner',Arial,sans-serif;font-size:14px;font-weight:500;color:rgba(158,160,198,0.72);line-height:20px;white-space:nowrap;padding-right:15px;"><a href="{{privacy_link}}" style="color:rgba(158,160,198,0.72);text-decoration:none;">Privacy</a></td>
            <td style="font-family:Arial,sans-serif;font-size:12px;color:rgba(158,160,198,0.36);line-height:18px;white-space:nowrap;padding-right:15px;">|</td>
            <td style="font-family:'Commissioner',Arial,sans-serif;font-size:14px;font-weight:500;color:rgba(158,160,198,0.72);line-height:20px;white-space:nowrap;padding-right:15px;"><a href="{{cookies_link}}" style="color:rgba(158,160,198,0.72);text-decoration:none;">Cookies</a></td>
            <td style="font-family:Arial,sans-serif;font-size:12px;color:rgba(158,160,198,0.36);line-height:18px;white-space:nowrap;padding-right:15px;">|</td>
            <td style="font-family:'Commissioner',Arial,sans-serif;font-size:14px;font-weight:500;color:rgba(158,160,198,0.72);line-height:20px;white-space:nowrap;"><a href="{{refunds_link}}" style="color:rgba(158,160,198,0.72);text-decoration:none;">Refunds</a></td>
          </tr>
        </table>
        </td>
      </tr>
    </table>
    </td>
  </tr>

</table>
</td>
</tr>
</table>

</body>
</html>
